# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Gemini AI
# Get API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
FALLBACK_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Flow EVM Configuration
FLOW_EVM_RPC=https://testnet.evm.nodes.onflow.org
NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
PAYMENTS_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
USDC_CONTRACT_ADDRESS=0x_usdc_contract_on_flow_evm_testnet
INR_PER_USD=83
FLOW_USD_PRICE=3.5

# Server Configuration
PORT=8001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000
CLIENT_PORTAL_SIGNING_SECRET=replace_with_a_long_random_secret

# ============================================
# v7 NEW ADDITIONS - Telegram & x402 Payments
# ============================================

# Telegram Bot Configuration
# Create bots via @BotFather on Telegram
TELEGRAM_ADMIN_BOT_TOKEN=123456:ABC-your-admin-bot-token
TELEGRAM_CLIENT_BOT_TOKEN=789012:DEF-your-client-bot-token
TELEGRAM_ADMIN_BOT_USERNAME=KhataFlowAdminBot
TELEGRAM_CLIENT_BOT_USERNAME=KhataFlowClientBot

# URLs (for payment links, QR codes, and notifications)
BACKEND_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000
